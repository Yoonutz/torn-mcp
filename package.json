{
  "name": "torn-mcp",
  "version": "0.1.0",
  "description": "Remote MCP server for the Torn City API v2, on Cloudflare Workers",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
