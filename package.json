{
  "name": "torn-mcp",
  "version": "0.9.3",
  "description": "Remote MCP server for the Torn City API v2, on Cloudflare Workers",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:types": "openapi-typescript openapi.json -o src/generated/types.ts",
    "generate": "node scripts/generate-endpoints.mjs && npm run gen:types",
    "sync-openapi": "node scripts/sync-openapi.mjs && npm run gen:types",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250510.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.4",
    "vitest": "^3.2.6",
    "wrangler": "^4.14.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
